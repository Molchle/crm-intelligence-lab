---
import fs from 'node:fs';
import path from 'node:path';
import Layout from '../layouts/Layout.astro';

export async function getStaticPaths() {
  const dataPath = path.resolve(process.cwd(), '../data/enriched_crms.json');
  const rawData = fs.readFileSync(dataPath, 'utf-8');
  const crms = JSON.parse(rawData);

  return crms.map((crm) => ({
    params: { id: crm.id },
    props: { crm },
  }));
}

const { crm } = Astro.props;

// Zde generujeme Structured Data (Google Rich Snippets)
const jsonLdSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Review",
  "itemReviewed": {
    "@type": "SoftwareApplication",
    "name": crm.name,
    "applicationCategory": "BusinessApplication",
    "operatingSystem": "Cloud, Web-based"
  },
  "reviewRating": {
    "@type": "Rating",
    "ratingValue": crm.efficiency_coefficient,
    "bestRating": "10.0",
    "worstRating": "1.0"
  },
  "author": {
    "@type": "Organization",
    "name": "CRM Intelligence Lab"
  },
  "reviewBody": crm.executive_summary
});
---

<Layout 
  title={`${crm.name} Architecture Review | CRM Intelligence Lab`}
  description={crm.executive_summary}
  schema={jsonLdSchema}
>
  <div class="min-h-screen flex flex-col bg-slate-50 font-sans selection:bg-indigo-500/30 text-slate-900">
    
    <div class="relative bg-slate-900 text-white pb-36 overflow-hidden">
      <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[800px] h-[400px] bg-indigo-500/20 blur-[120px] rounded-full pointer-events-none"></div>
      <div class="absolute top-20 right-0 w-[400px] h-[400px] bg-violet-500/10 blur-[100px] rounded-full pointer-events-none"></div>
      
      <nav class="relative z-10 border-b border-white/5">
        <div class="max-w-5xl mx-auto px-6 py-5 flex justify-between items-center">
          <div class="flex items-center gap-3 text-xs font-mono text-slate-400 uppercase tracking-widest">
            <a href="/" class="hover:text-white transition-colors">Intelligence Registry</a>
            <span class="text-slate-600">/</span>
            <span class="text-indigo-200 font-semibold">{crm.name}</span>
          </div>
          <div class="flex items-center gap-2.5 bg-emerald-500/10 border border-emerald-500/20 px-3.5 py-1.5 rounded-full shadow-[0_0_15px_rgba(16,185,129,0.1)]">
            <div class="w-1.5 h-1.5 bg-emerald-400 rounded-full animate-pulse"></div>
            <span class="text-[10px] font-mono font-bold text-emerald-400 uppercase tracking-widest">
              Active Analysis
            </span>
          </div>
        </div>
      </nav>

      <header class="relative z-10 max-w-5xl mx-auto px-6 pt-20 md:pt-28" id="hero-header">
        <h1 class="text-6xl md:text-8xl font-black tracking-tighter text-white mb-6 drop-shadow-sm">
          {crm.name}
        </h1>
        <p class="text-xl md:text-2xl text-slate-300/90 leading-relaxed font-light max-w-3xl tracking-tight mb-10">
          {crm.executive_summary}
        </p>

        <div class="flex flex-col sm:flex-row gap-4">
          <a href={crm.affiliate_url} target="_blank" rel="noopener noreferrer" class="group relative inline-flex items-center justify-center gap-3 bg-white text-slate-900 font-bold text-base px-8 py-4 rounded-xl hover:bg-indigo-50 transition-all duration-200 shadow-[0_0_40px_rgba(255,255,255,0.1)] hover:shadow-[0_0_60px_rgba(99,102,241,0.2)] hover:-translate-y-0.5 active:scale-95">
            <span>Activate Intelligence Access</span>
            <svg width="20" height="20" class="text-indigo-600 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path>
            </svg>
          </a>
          <a href="#analysis" class="inline-flex items-center justify-center gap-2 text-slate-300 hover:text-white font-medium px-6 py-4 rounded-xl border border-white/10 hover:bg-white/5 transition-colors">
            Read Architecture
            <svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24" class="opacity-70">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"></path>
            </svg>
          </a>
        </div>
      </header>
    </div>

    <main id="analysis" class="flex-grow max-w-5xl mx-auto px-6 -mt-10 relative z-20 w-full pb-40">
      
      <div class="grid grid-cols-1 md:grid-cols-3 gap-5 md:gap-6 mb-16">
        <div class="bg-white/90 backdrop-blur-sm rounded-xl p-8 shadow-sm border border-slate-200 border-t-4 border-t-indigo-500 hover:-translate-y-1.5 hover:shadow-xl transition-all duration-300">
          <span class="text-[10px] font-mono text-indigo-600 font-bold uppercase tracking-widest mb-3 block">Efficiency Coefficient</span>
          <span class="text-5xl font-black text-slate-900 tracking-tighter">{crm.efficiency_coefficient}</span>
        </div>
        <div class="bg-white/90 backdrop-blur-sm rounded-xl p-8 shadow-sm border border-slate-200 border-t-4 border-t-emerald-500 hover:-translate-y-1.5 hover:shadow-xl transition-all duration-300 flex flex-col justify-end">
          <span class="text-[10px] font-mono text-slate-400 font-bold uppercase tracking-widest mb-3 block">Deployment Window</span>
          <span class="text-2xl font-bold text-slate-800 tracking-tight">{crm.implementation_window}</span>
        </div>
        <div class="bg-white/90 backdrop-blur-sm rounded-xl p-8 shadow-sm border border-slate-200 border-t-4 border-t-violet-500 hover:-translate-y-1.5 hover:shadow-xl transition-all duration-300 flex flex-col justify-end">
          <span class="text-[10px] font-mono text-slate-400 font-bold uppercase tracking-widest mb-3 block">Resource Load</span>
          <span class="text-2xl font-bold text-slate-800 tracking-tight">{crm.resource_requirement}</span>
        </div>
      </div>

      <div class="space-y-16 max-w-4xl mx-auto bg-white p-8 md:p-16 rounded-2xl shadow-sm border border-slate-200">
        
        <section>
          <div class="flex items-center gap-4 mb-6">
            <span class="flex items-center justify-center w-8 h-8 rounded-full bg-indigo-50 text-indigo-600 font-mono text-sm font-bold border border-indigo-100">1</span>
            <h2 class="text-xl font-bold text-slate-900 tracking-tight">Core Architecture & Utility</h2>
          </div>
          <p class="text-lg text-slate-600 leading-relaxed pl-12">
            {crm.core_utility}
          </p>
        </section>

        <section class="ml-12 relative overflow-hidden rounded-xl bg-rose-50/50 border border-rose-100 p-6 md:p-8">
          <div class="absolute left-0 top-0 bottom-0 w-1.5 bg-rose-400"></div>
          
          <div class="flex items-center gap-3 mb-4">
            <svg width="20" height="20" class="text-rose-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path>
            </svg>
            <h2 class="text-sm font-bold text-rose-900 uppercase tracking-widest">Operational Bottlenecks</h2>
          </div>
          <p class="text-base font-mono text-rose-950/80 leading-relaxed">
            {crm.operational_friction}
          </p>
        </section>

        <section>
          <div class="flex items-center gap-4 mb-6">
            <span class="flex items-center justify-center w-8 h-8 rounded-full bg-indigo-50 text-indigo-600 font-mono text-sm font-bold border border-indigo-100">2</span>
            <h2 class="text-xl font-bold text-slate-900 tracking-tight">Strategic Rationale</h2>
          </div>
          <p class="text-lg text-slate-600 leading-relaxed pl-12">
            {crm.direct_access_rationale}
          </p>
        </section>

        <div class="ml-12 mt-12 pt-8 border-t border-slate-100 flex flex-col sm:flex-row items-center justify-between gap-6">
          <div>
            <h3 class="text-slate-900 font-bold mb-1">Ready to deploy {crm.name}?</h3>
            <p class="text-sm text-slate-500">Access our exclusive partner routing.</p>
          </div>
          <a href={crm.affiliate_url} target="_blank" rel="noopener noreferrer" class="w-full sm:w-auto bg-indigo-600 hover:bg-indigo-700 text-white font-semibold px-6 py-3 rounded-lg transition-colors flex items-center justify-center gap-2 shadow-sm active:scale-95">
            Claim Partner Setup
            <svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path>
            </svg>
          </a>
        </div>

      </div>
    </main>

    <div id="sticky-bar" class="fixed bottom-6 left-1/2 -translate-x-1/2 w-[90%] max-w-2xl z-50 pointer-events-none opacity-0 translate-y-8 transition-all duration-300">
      <div class="bg-white/80 backdrop-blur-xl border border-white/60 shadow-[0_8px_30px_rgb(0,0,0,0.12)] rounded-2xl p-2.5 flex items-center justify-between gap-4 pointer-events-auto">
        
        <div class="hidden sm:flex items-center gap-4 pl-4">
          <div class="w-8 h-8 rounded-full bg-indigo-50 flex items-center justify-center border border-indigo-100">
            <svg width="16" height="16" class="text-indigo-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path></svg>
          </div>
          <div class="flex flex-col">
            <span class="text-slate-900 font-bold text-sm leading-none mb-1">Partner Routing Active</span>
            <span class="text-[10px] font-mono text-indigo-600 uppercase tracking-wider leading-none">*Optimal terms applied</span>
          </div>
        </div>
        
        <a href={crm.affiliate_url} target="_blank" rel="noopener noreferrer" class="w-full sm:w-auto bg-slate-900 hover:bg-slate-800 text-white font-semibold text-sm px-6 py-2.5 rounded-xl transition-colors flex items-center justify-center gap-2 active:scale-95">
          Unlock Preferred Deployment
          <svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path>
          </svg>
        </a>
        
      </div>
    </div>

  </div>
</Layout>

<script>
  // Simple intersection observer to show/hide the sticky bar based on hero visibility
  const observer = new IntersectionObserver((entries) => {
    const stickyBar = document.getElementById('sticky-bar');
    entries.forEach(entry => {
      if (!entry.isIntersecting) {
        // Hero is out of view -> show sticky bar
        stickyBar?.classList.remove('opacity-0', 'translate-y-8');
        stickyBar?.classList.add('opacity-100', 'translate-y-0');
      } else {
        // Hero is visible -> hide sticky bar
        stickyBar?.classList.add('opacity-0', 'translate-y-8');
        stickyBar?.classList.remove('opacity-100', 'translate-y-0');
      }
    });
  }, { threshold: 0.1 });

  const heroHeader = document.getElementById('hero-header');
  if (heroHeader) observer.observe(heroHeader);
</script>