---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';

// Bleskurychlé načtení z naší nové lokální databáze (včetně NOVÝCH srovnání)
const crms = await getCollection('crms');
const integrations = await getCollection('integrations');
const comparisons = await getCollection('comparisons');
const usecases = await getCollection('usecases'); // <-- TOTO PŘIDEJ

// Seřazení CRM podle ceny
const sortedCrms = crms.sort((a, b) => a.data.starting_price - b.data.starting_price);
---

<Layout title="CRM Intelligence Lab | Enterprise Architecture Hub">
  <main class="bg-slate-50 min-h-screen pb-24 font-sans text-slate-900 overflow-x-hidden">
    
    <header class="bg-slate-950 text-white pt-20 pb-20 px-6 relative overflow-hidden">
      <div class="max-w-7xl mx-auto text-center relative z-10 py-10">
        <h1 class="text-5xl md:text-7xl font-black tracking-tight mb-6 leading-tight">
          B2B Software <span class="text-transparent bg-clip-text bg-gradient-to-r from-indigo-400 to-cyan-400">Technical Debt</span> Database
        </h1>
        <p class="text-lg text-slate-400 font-light max-w-2xl mx-auto mb-10">
          Objective architecture audits, API rate limit analysis, and integration friction reports for enterprise CRM systems.
        </p>
      </div>
    </header>

    <section class="max-w-7xl mx-auto px-6 -mt-12 relative z-20 mb-20">
      <div class="bg-white rounded-2xl shadow-xl shadow-slate-200/50 border border-slate-200 p-8 md:p-10 grid grid-cols-1 md:grid-cols-3 gap-8">
        <div>
          <div class="w-10 h-10 bg-indigo-50 text-indigo-600 rounded-lg flex items-center justify-center mb-4">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path></svg>
          </div>
          <h3 class="text-sm font-black uppercase tracking-widest mb-2 text-slate-900">Zero Sponsored Placements</h3>
          <p class="text-sm text-slate-500 leading-relaxed">Software companies cannot pay to rank higher in our database. We sort by strict architectural merit.</p>
        </div>
        <div>
          <div class="w-10 h-10 bg-emerald-50 text-emerald-600 rounded-lg flex items-center justify-center mb-4">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"></path></svg>
          </div>
          <h3 class="text-sm font-black uppercase tracking-widest mb-2 text-slate-900">API Friction Testing</h3>
          <p class="text-sm text-slate-500 leading-relaxed">We don't read marketing brochures. We evaluate actual REST API rate limits and data mapping complexities.</p>
        </div>
        <div>
          <div class="w-10 h-10 bg-amber-50 text-amber-600 rounded-lg flex items-center justify-center mb-4">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
          </div>
          <h3 class="text-sm font-black uppercase tracking-widest mb-2 text-slate-900">Real-World Deployments</h3>
          <p class="text-sm text-slate-500 leading-relaxed">Our implementation estimates include historical data mapping, team onboarding, and custom object setup.</p>
        </div>
      </div>
    </section>

    <section class="max-w-7xl mx-auto px-6 relative z-10 mb-20">
      <div class="flex items-center justify-between mb-6">
        <h2 class="text-lg font-bold tracking-tight text-slate-500 uppercase font-mono mb-6">Verified Core CRM Systems</h2>
        <span class="text-xs font-mono text-slate-500 bg-slate-200 px-3 py-1 rounded-full">{crms.length} Systems</span>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
        {sortedCrms.map((crm) => (
          <div class="bg-white rounded-xl p-6 shadow-xl shadow-slate-200/50 border border-slate-200 transition-all hover:border-indigo-300 group">
            <h3 class="text-xl font-black mb-1 text-slate-900">{crm.data.name}</h3>
            <div class="text-xs font-mono text-slate-400 mb-6">{crm.data.primary_category}</div>
            
            <div class="mb-6 flex items-baseline gap-1">
              <span class="text-4xl font-black text-slate-950">${crm.data.starting_price}</span>
              <span class="text-sm text-slate-400 font-medium">/mo</span>
            </div>
            
            <a href={crm.data.affiliate_url} target="_blank" rel="noopener noreferrer" class="block w-full bg-slate-100 group-hover:bg-indigo-600 group-hover:text-white text-slate-900 text-center text-sm font-bold py-3 px-4 rounded-lg transition-all shadow-sm">
              Verify Pricing
            </a>
          </div>
        ))}
      </div>
    </section>

    <section class="max-w-7xl mx-auto px-6 mb-20 pt-10 border-t border-slate-200">
      <div class="flex items-center justify-between mb-8 pb-4">
        <h2 class="text-2xl font-black tracking-tight">Ecosystem & Integration Reports</h2>
        <span class="text-xs font-mono text-indigo-600 bg-indigo-100 px-3 py-1 rounded-full font-bold">{integrations.length} Reports</span>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {integrations.map((integration) => (
          <a href={`/integrations/${integration.id}`} class="block bg-white rounded-xl p-6 border border-slate-200 hover:border-indigo-400 hover:shadow-lg transition-all group relative overflow-hidden">
            <div class="absolute top-0 left-0 w-1.5 h-full bg-indigo-500 opacity-0 group-hover:opacity-100 transition-opacity"></div>
            
            <div class="flex justify-between items-center mb-5">
              <div class="text-[10px] font-mono text-slate-400 uppercase tracking-widest flex items-center gap-2">
                <svg class="w-4 h-4 text-indigo-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
                Integration Brief
              </div>
              <div class={`text-[10px] font-bold px-2 py-0.5 rounded uppercase ${integration.data.friction_rating <= 3 ? 'bg-emerald-100 text-emerald-700' : integration.data.friction_rating <= 7 ? 'bg-amber-100 text-amber-900' : 'bg-red-100 text-red-700'}`}>
                Friction: {integration.data.friction_rating}/10
              </div>
            </div>
            
            <h3 class="text-lg font-bold text-slate-900 group-hover:text-indigo-600 transition-colors mb-2 leading-tight">
              {integration.data.seo_title}
            </h3>
            
            <div class="text-[11px] text-slate-500 font-mono mt-6 flex items-center gap-4 pt-4 border-t border-slate-100">
              <span class="font-medium text-slate-700">{integration.data.sync_direction}</span>
              <span class="text-slate-200">|</span>
              <span>{integration.data.setup_time}</span>
            </div>
          </a>
        ))}
      </div>
    </section>

    <section class="max-w-7xl mx-auto px-6 mb-20 pt-10 border-t border-slate-200">
      <div class="flex items-center justify-between mb-8 pb-4">
        <h2 class="text-2xl font-black tracking-tight">Architecture Duels (Versus)</h2>
        <span class="text-xs font-mono text-emerald-700 bg-emerald-100 px-3 py-1 rounded-full font-bold">{comparisons.length} Face-offs</span>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {comparisons.map((comp) => (
          <a href={`/compare/${comp.id}`} class="block bg-white rounded-xl p-6 border border-slate-200 hover:border-emerald-400 hover:shadow-lg transition-all group relative overflow-hidden">
            <div class="absolute top-0 left-0 w-1.5 h-full bg-emerald-500 opacity-0 group-hover:opacity-100 transition-opacity"></div>

            <div class="flex justify-between items-center mb-5">
              <div class="text-[10px] font-mono text-slate-400 uppercase tracking-widest flex items-center gap-2">
                <svg class="w-4 h-4 text-emerald-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 6l3 1m0 0l-3 9a5.002 5.002 0 006.001 0M6 7l3 9M6 7l6-2m6 2l3-1m-3 1l-3 9a5.002 5.002 0 006.001 0M18 7l3 9m-3-9l-6-2m0-2v2m0 16V5m0 16H9m3 0h3"></path></svg>
                Head-to-Head
              </div>
              <div class={`text-[10px] font-bold px-2 py-0.5 rounded uppercase ${comp.data.winner === 'Core' ? 'bg-emerald-100 text-emerald-800' : comp.data.winner === 'Tie' ? 'bg-amber-100 text-amber-800' : 'bg-slate-100 text-slate-700'}`}>
                {comp.data.winner === 'Core' ? 'Clear Winner' : comp.data.winner === 'Tie' ? 'Tie' : 'Alternative'}
              </div>
            </div>

            <h3 class="text-lg font-bold text-slate-900 group-hover:text-emerald-600 transition-colors mb-2 leading-tight">
              {comp.data.seo_title.replace(': Architecture Comparison', '')}
            </h3>

            <div class="text-[11px] text-slate-500 font-mono mt-6 flex flex-wrap items-center gap-3 pt-4 border-t border-slate-100">
              <span class="font-medium text-slate-700">Migration: {comp.data.migration_difficulty}</span>
              <span class="text-slate-200 hidden sm:inline">|</span>
              <span class="truncate block w-full sm:w-auto mt-1 sm:mt-0">Ideal: {comp.data.ideal_for_core}</span>
            </div>
          </a>
        ))}
      </div>
    </section>

<section class="max-w-7xl mx-auto px-6 mb-32 pt-10 border-t border-slate-200">
      <div class="flex items-center justify-between mb-8 pb-4">
        <h2 class="text-2xl font-black tracking-tight">Industry Deployments</h2>
        <span class="text-xs font-mono text-cyan-700 bg-cyan-100 px-3 py-1 rounded-full font-bold">{usecases.length} Blueprints</span>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
        {usecases.map((uc) => (
          <a href={`/industries/${uc.id}`} class="block bg-slate-950 rounded-xl p-6 border border-slate-800 hover:border-cyan-400 hover:shadow-lg transition-all group relative overflow-hidden text-white">
            <div class="absolute top-0 left-0 w-1.5 h-full bg-cyan-500 opacity-0 group-hover:opacity-100 transition-opacity"></div>

            <div class="text-[10px] font-mono text-cyan-400 uppercase tracking-widest flex items-center gap-2 mb-4">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"></path></svg>
              Architecture Blueprint
            </div>

            <h3 class="text-lg font-bold text-white group-hover:text-cyan-400 transition-colors mb-2 leading-tight">
              {uc.data.industry}
            </h3>

            <div class="text-[11px] text-slate-400 font-mono mt-6 flex flex-col gap-2 pt-4 border-t border-slate-800">
              <span class="font-medium text-slate-300">Base: {uc.data.core_crm_id.toUpperCase()}</span>
              <span>Setup: {uc.data.setup_time}</span>
            </div>
          </a>
        ))}
      </div>
    </section>

  </main>
</Layout>