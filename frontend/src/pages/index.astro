---
import Layout from '../layouts/Layout.astro';
import fs from 'node:fs';
import path from 'node:path';

// 1. Načtení všech datových matic
const crmsPath = path.resolve(process.cwd(), '../data/enriched_crms.json');
const crms = JSON.parse(fs.readFileSync(crmsPath, 'utf-8'));

const comparisonsPath = path.resolve(process.cwd(), '../data/enriched_comparisons.json');
const comparisons = JSON.parse(fs.readFileSync(comparisonsPath, 'utf-8'));

const usecasesPath = path.resolve(process.cwd(), '../data/enriched_usecases.json');
const usecases = JSON.parse(fs.readFileSync(usecasesPath, 'utf-8'));
---

<Layout title="CRM Intelligence Lab | Technical Audits & Architecture Reviews">
  <main class="bg-slate-50 min-h-screen pb-24 font-sans text-slate-900">
    
    <header class="bg-slate-950 text-white pt-24 pb-20 px-6">
      <div class="max-w-6xl mx-auto text-center">
        <h1 class="text-5xl md:text-7xl font-black tracking-tight mb-6">
          B2B Software <span class="text-transparent bg-clip-text bg-gradient-to-r from-indigo-400 to-cyan-400">Technical Debt</span> Database
        </h1>
        <p class="text-xl text-slate-400 font-light max-w-2xl mx-auto">
          Objective architecture audits, API rate limit analysis, and integration friction reports for enterprise CRM systems.
        </p>
      </div>
    </header>

    <section class="max-w-6xl mx-auto px-6 -mt-10 relative z-10 mb-20">
      <div class="flex items-center justify-between mb-6">
        <h2 class="text-2xl font-black tracking-tight">Core Architecture Audits</h2>
        <span class="text-sm font-mono text-slate-500 bg-slate-200 px-3 py-1 rounded-full">{crms.length} Systems</span>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {crms.map((crm) => (
          <a href={`/${crm.id}`} class="block bg-white rounded-2xl p-6 shadow-sm border border-slate-200 hover:shadow-xl hover:border-indigo-300 transition-all group">
            <div class="text-xs font-mono text-indigo-500 mb-2 uppercase tracking-widest">{crm.tech_id}</div>
            <h3 class="text-xl font-bold mb-2 group-hover:text-indigo-600 transition-colors">{crm.name}</h3>
            <p class="text-sm text-slate-500 line-clamp-2">{crm.executive_summary}</p>
          </a>
        ))}
      </div>
    </section>

    <section class="max-w-6xl mx-auto px-6 mb-20">
      <div class="flex items-center justify-between mb-6 border-b border-slate-200 pb-4">
        <h2 class="text-2xl font-black tracking-tight">Architecture Duels (Comparisons)</h2>
        <span class="text-sm font-mono text-slate-500 bg-slate-200 px-3 py-1 rounded-full">{comparisons.length} Reports</span>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-3">
        {comparisons.map((comp) => (
          <a href={`/compare/${comp.id}`} class="block bg-white rounded-lg p-4 border border-slate-200 hover:bg-slate-900 hover:text-white transition-colors group">
            <h3 class="text-sm font-bold tracking-tight">{comp.title.replace(' Architecture Comparison', '')}</h3>
            <div class="text-xs text-slate-400 mt-2 group-hover:text-slate-300 flex items-center gap-1">
              Read technical analysis <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
            </div>
          </a>
        ))}
      </div>
    </section>

    <section class="max-w-6xl mx-auto px-6 mb-10">
      <div class="flex items-center justify-between mb-6 border-b border-slate-200 pb-4">
        <h2 class="text-2xl font-black tracking-tight">Industry Deployments</h2>
        <span class="text-sm font-mono text-slate-500 bg-slate-200 px-3 py-1 rounded-full">{usecases.length} Scenarios</span>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
        {usecases.map((uc) => (
          <a href={`#`} class="block bg-slate-100 rounded-lg p-4 border border-slate-200 hover:border-slate-300 opacity-60 hover:opacity-100 transition-opacity">
            <div class="text-xs font-mono text-slate-500 mb-1">{uc.industry}</div>
            <h3 class="text-sm font-bold text-slate-800">{uc.crm_id.toUpperCase()} Deployment</h3>
            <div class="text-xs text-amber-600 mt-2 font-mono">Template pending...</div>
          </a>
        ))}
      </div>
    </section>

  </main>
</Layout>