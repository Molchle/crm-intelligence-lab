---
import fs from 'node:fs';
import path from 'node:path';
import Layout from '../layouts/Layout.astro';

// Načtení dat
const dataPath = path.resolve(process.cwd(), '../data/enriched_crms.json');
const rawData = fs.readFileSync(dataPath, 'utf-8');
const crms = JSON.parse(rawData);
---

<Layout title="CRM Intelligence Lab | Independent Technical Audits">
  <div class="min-h-screen flex flex-col">
    <div class="max-w-5xl mx-auto px-6 py-16 md:py-24 flex-grow w-full">
      
      <header class="mb-20 border-b border-slate-200 pb-12">
        <div class="flex items-center gap-3 mb-6">
          <div class="w-1.5 h-1.5 bg-indigo-600 rounded-full"></div>
          <span class="text-[11px] font-mono font-semibold text-slate-500 uppercase tracking-widest">Research & Advisory / Q1 2026</span>
        </div>
        <h1 class="text-4xl md:text-5xl font-semibold tracking-tight text-slate-900 mb-6">
          Enterprise CRM Intelligence
        </h1>
        <p class="text-lg text-slate-500 max-w-2xl leading-relaxed">
          Independent technical analysis of CRM infrastructures. We evaluate operational reality, technical debt, and true implementation costs. Stripped of marketing bias.
        </p>
      </header>

      <main class="grid grid-cols-1 md:grid-cols-2 gap-8">
        {crms.map((crm) => (
          <a 
            href={`/${crm.id}`} 
            class="group flex flex-col bg-white border border-slate-200 p-8 hover:border-indigo-300 hover:shadow-[0_8px_30px_rgb(0,0,0,0.04)] transition-all duration-300"
          >
            <div class="flex justify-between items-start mb-6">
              <span class="font-mono text-[11px] text-slate-400 uppercase tracking-wider">
                {crm.base_category}
              </span>
              <div class="flex items-center gap-2">
                <span class="font-mono text-[10px] text-slate-400 uppercase tracking-wider">Score</span>
                <span class="font-mono text-sm font-semibold bg-slate-50 text-slate-700 px-2 py-0.5 border border-slate-200 group-hover:bg-indigo-50 group-hover:text-indigo-700 group-hover:border-indigo-200 transition-colors">
                  {crm.efficiency_coefficient}
                </span>
              </div>
            </div>
            
            <h2 class="text-2xl font-semibold mb-4 text-slate-900 group-hover:text-indigo-600 transition-colors">
              {crm.name}
            </h2>
            
            <p class="text-slate-600 text-sm leading-relaxed mb-8 line-clamp-3">
              {crm.executive_summary}
            </p>
            
            <div class="mt-auto border-t border-slate-100 pt-5 flex items-center justify-between">
              <span class="text-sm font-medium text-indigo-600 flex items-center group-hover:text-indigo-700 transition-colors">
                View Technical Audit
                <svg class="w-4 h-4 ml-1.5 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path>
                </svg>
              </span>
              <span class="text-[10px] font-mono text-slate-300">ID: {crm.tech_id}</span>
            </div>
          </a>
        ))}
      </main>
    </div>

    <footer class="border-t border-slate-200 bg-white mt-auto">
      <div class="max-w-5xl mx-auto px-6 py-12 flex flex-col md:flex-row justify-between items-start md:items-center gap-8">
        <div class="flex flex-col gap-2">
          <span class="text-sm font-semibold text-slate-900">CRM Intelligence Lab</span>
          <span class="text-xs text-slate-500">&copy; 2026 All rights reserved.</span>
        </div>
        
        <div class="max-w-md text-xs text-slate-400 leading-relaxed md:text-right">
          Our research methodology focuses on engineering truth. We may earn a commission if you initialize a deployment instance through our links. This financial structure never influences our operational friction analysis.
        </div>
      </div>
    </footer>
  </div>
</Layout>