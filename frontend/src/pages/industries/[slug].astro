---
import { getCollection, getEntry } from 'astro:content';
import Layout from '../../layouts/Layout.astro'; 

export async function getStaticPaths() {
  const usecases = await getCollection('usecases');
  
  return usecases.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const usecase = entry.data;

// Načteme nadřazené CRM pro sidebar a affiliate odkaz
const coreCrm = await getEntry('crms', usecase.core_crm_id);

if (!coreCrm) {
  throw new Error(`Kritická chyba: CRM s ID ${usecase.core_crm_id} nebylo nalezeno!`);
}

const crmData = coreCrm.data;
---

<Layout title={`${usecase.seo_title} | CRM Intelligence Lab`} description={usecase.ai_architect_verdict.substring(0, 150)}>
  <div class="min-h-screen bg-slate-50 font-sans text-slate-900 pb-32 pt-24">
    <div class="max-w-7xl mx-auto px-6 grid grid-cols-1 lg:grid-cols-12 gap-12">
      
      <main class="lg:col-span-8">
        
        <div class="mb-10 p-2">
          <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-slate-200/60 text-slate-600 text-xs font-mono uppercase tracking-widest mb-4">
            Industry Deployment Architecture
          </div>
          <h1 class="text-4xl md:text-5xl font-black tracking-tight mb-8 text-slate-900 leading-tight">
            {usecase.seo_title}
          </h1>
          
          <div class="grid grid-cols-2 md:grid-cols-3 gap-5 mb-10">
            <div class="bg-white p-5 rounded-2xl border border-slate-200 shadow-sm">
              <div class="text-[10px] text-slate-400 font-mono uppercase mb-1.5 tracking-wide">Target Industry</div>
<div class="font-extrabold text-base leading-tight text-slate-950 line-clamp-2 whitespace-normal" title={usecase.industry}>{usecase.industry}</div>
            </div>
            
            <div class="bg-indigo-50 p-5 rounded-2xl border border-indigo-200 shadow-sm text-indigo-900">
              <div class="text-[10px] opacity-70 font-mono uppercase mb-1.5 tracking-wide">Compliance Standard</div>
              <div class="font-extrabold text-lg flex items-center gap-2">
                <svg class="w-5 h-5 text-indigo-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path></svg>
                {usecase.compliance_standard}
              </div>
            </div>
            
            <div class="bg-white p-5 rounded-2xl border border-slate-200 shadow-sm hidden md:block">
              <div class="text-[10px] text-slate-400 font-mono uppercase mb-1.5 tracking-wide">Est. Setup Time</div>
              <div class="font-extrabold text-lg text-slate-950">{usecase.setup_time}</div>
            </div>
          </div>
        </div>

        <div class="bg-white rounded-3xl p-8 md:p-10 border border-slate-200 shadow-lg shadow-slate-100/50 mb-10">
          <h2 class="text-2xl font-black mb-8 flex items-center gap-3 border-b border-slate-100 pb-4">
            <svg class="w-6 h-6 text-indigo-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"></path></svg>
            Industry Challenges & Architectural Solutions
          </h2>
          
          <div class="space-y-8">
            {usecase.industry_pain_points.map((pain, index) => (
              <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <div class="bg-red-50/50 rounded-2xl p-5 border border-red-100">
                  <div class="text-[10px] font-mono text-red-500 uppercase tracking-widest mb-2 flex items-center gap-2">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path></svg>
                    Friction Point {index + 1}
                  </div>
                  <p class="text-sm text-slate-700 font-medium">{pain}</p>
                </div>
                
                <div class="bg-emerald-50/50 rounded-2xl p-5 border border-emerald-100 relative">
                  <div class="hidden md:block absolute top-1/2 -left-3.5 w-7 h-7 bg-white border border-slate-200 rounded-full flex items-center justify-center transform -translate-y-1/2 z-10 text-slate-400">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
                  </div>
                  <div class="text-[10px] font-mono text-emerald-600 uppercase tracking-widest mb-2 flex items-center gap-2">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                    {crmData.name} Solution
                  </div>
                  <p class="text-sm text-slate-700 font-medium">{usecase.core_solutions[index]}</p>
                </div>
              </div>
            ))}
          </div>
        </div>

        <div class="bg-slate-950 rounded-3xl p-8 md:p-10 text-white mb-10 border border-slate-800 shadow-2xl">
          <h3 class="text-2xl font-black mb-8 flex items-center gap-3">
            <svg class="w-6 h-6 text-cyan-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 9l3 3-3 3m5 0h3M5 20h14a2 2 0 002-2V6a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
            Custom Object Architecture Mapping
          </h3>
          <p class="text-sm text-slate-400 mb-6 font-mono">Standard CRM entities mapped to {usecase.industry} taxonomy:</p>
          
          <div class="space-y-3">
            {usecase.custom_objects_mapping.map((mapping) => {
              const [standard, custom] = mapping.split('->').map(s => s.trim());
              return (
                <div class="flex items-center justify-between bg-slate-900 rounded-xl p-4 border border-slate-800">
                  <div class="w-1/3 text-sm font-mono text-slate-500 text-right">{standard || mapping}</div>
                  <div class="w-1/3 flex justify-center text-cyan-500">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path></svg>
                  </div>
                  <div class="w-1/3 text-sm font-bold text-cyan-50">{custom || ''}</div>
                </div>
              );
            })}
          </div>
        </div>

        <div class="bg-white rounded-3xl shadow-lg shadow-slate-100/50 border border-slate-200 p-8 md:p-12 prose prose-slate max-w-none prose-headings:font-black prose-p:text-slate-700 prose-p:leading-relaxed">
          <h2 class="text-3xl font-black mb-8 pb-4 border-b border-slate-100 flex items-center gap-3">
            <svg class="w-7 h-7 text-indigo-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path></svg>
            Deployment Verdict
          </h2>
          <div class="space-y-6 text-sm leading-relaxed prose prose-slate prose-sm max-w-none">
            {usecase.ai_architect_verdict.split('\n').filter(p => p.trim() !== '').map((paragraph) => (
              <p>{paragraph}</p>
            ))}
          </div>
        </div>

      </main>

      <aside class="lg:col-span-4 relative">
        <div class="sticky top-24 bg-white rounded-3xl p-8 shadow-xl shadow-slate-200/50 border border-slate-200">
          
          <div class="flex items-center justify-between mb-8 pb-6 border-b border-slate-100 gap-4">
            <div>
              <div class="text-[11px] font-mono text-indigo-500 mb-1.5 uppercase tracking-widest">Recommended Core</div>
              <h3 class="text-2xl font-black text-slate-950">{crmData.name}</h3>
            </div>
            {crmData.has_free_tier && (
              <span class="bg-emerald-100 text-emerald-800 text-xs font-bold px-2.5 py-1 rounded-full uppercase tracking-wide">Free Tier</span>
            )}
          </div>
          
          <div class="mb-8 p-4 bg-slate-50 rounded-xl border border-slate-100">
            <div class="text-sm text-slate-500 mb-1.5 font-medium">Starting at</div>
            <div class="text-4xl font-black text-slate-950 mb-1 flex items-baseline gap-1">
              ${crmData.starting_price}
              <span class="text-lg text-slate-400 font-normal">/mo</span>
            </div>
            <div class="text-[11px] text-slate-400 font-mono uppercase tracking-wide">{crmData.primary_category}</div>
          </div>

          {crmData.features && crmData.features.length > 0 && (
            <ul class="space-y-4 mb-10">
              {crmData.features.map(feature => (
                <li class="flex items-center gap-3.5 text-sm text-slate-700 font-medium">
                  <svg class="w-5 h-5 text-indigo-500 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                  {feature}
                </li>
              ))}
            </ul>
          )}

          <a href={crmData.affiliate_url} target="_blank" rel="noopener noreferrer" class="block w-full bg-slate-950 hover:bg-indigo-600 text-white text-center font-bold py-4 px-6 rounded-2xl transition-all shadow-lg shadow-slate-900/10 mb-5">
            Verify Pricing & Sandbox
          </a>
          
          <div class="text-center text-xs text-slate-400 font-mono">
            Direct link to official {crmData.name} portal.
          </div>
        </div>
      </aside>

    </div>
  </div>
</Layout>