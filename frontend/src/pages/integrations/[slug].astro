---
import { getCollection, getEntry } from 'astro:content';
import Layout from '../../layouts/Layout.astro'; 

export async function getStaticPaths() {
  const integrations = await getCollection('integrations');
  
  return integrations.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const integration = entry.data;

const coreCrm = await getEntry('crms', integration.core_crm_id);

if (!coreCrm) {
  throw new Error(`Kritická chyba: CRM s ID ${integration.core_crm_id} nebylo nalezeno v databázi!`);
}

const crmData = coreCrm.data;

// OPRAVA: Lepší barvy a ČITELNOST Friction Ratingu (žádné žluté na žlutém)
const getFrictionColorClasses = (rating: number) => {
  if (rating <= 3) return 'text-emerald-700 bg-emerald-50 border-emerald-200';
  if (rating <= 7) return 'text-amber-950 bg-amber-100 border-amber-300';
  return 'text-red-700 bg-red-50 border-red-200';
};
---

<Layout title={`${integration.seo_title} | CRM Intelligence Lab`} description={integration.ai_technical_analysis.substring(0, 150)}>
  <div class="min-h-screen bg-slate-50 font-sans text-slate-900 pb-32 pt-24">
    <div class="max-w-7xl mx-auto px-6 grid grid-cols-1 lg:grid-cols-12 gap-12">
      
      <main class="lg:col-span-8">
        
        <div class="mb-10">
          <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-slate-200/60 text-slate-600 text-xs font-mono uppercase tracking-widest mb-4">
            Ecosystem Integration Report
          </div>
          <h1 class="text-4xl md:text-5xl font-black tracking-tight mb-8 text-slate-900 leading-tight">
            {integration.seo_title}
          </h1>
          
          <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-10">
            <div class="bg-white p-4 rounded-xl border border-slate-200 shadow-sm">
              <div class="text-[10px] text-slate-400 font-mono uppercase mb-1">Architecture</div>
              <div class="font-bold text-sm">{integration.sync_direction}</div>
            </div>
            <div class={`p-4 rounded-xl border shadow-sm ${getFrictionColorClasses(integration.friction_rating)}`}>
              <div class="text-[10px] opacity-80 font-mono uppercase mb-1">Friction Rating</div>
              <div class="font-bold text-sm">{integration.friction_rating} / 10</div>
            </div>
            <div class="bg-white p-4 rounded-xl border border-slate-200 shadow-sm">
              <div class="text-[10px] text-slate-400 font-mono uppercase mb-1">Setup Time</div>
              <div class="font-bold text-sm">{integration.setup_time}</div>
            </div>
            <div class="bg-white p-4 rounded-xl border border-slate-200 shadow-sm hidden md:block">
              <div class="text-[10px] text-slate-400 font-mono uppercase mb-1">Target App</div>
              <div class="font-bold text-sm">{integration.app_name}</div>
            </div>
          </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-10">
          <div class="bg-emerald-50/50 rounded-2xl p-6 border border-emerald-100">
            <h3 class="text-sm font-black text-emerald-800 uppercase tracking-widest mb-4 flex items-center gap-2">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
              Advantages
            </h3>
            <ul class="space-y-3">
              {integration.pros.map(pro => (
                <li class="flex items-start gap-2 text-sm text-slate-700"><span class="text-emerald-500 font-bold mt-0.5">+</span> {pro}</li>
              ))}
            </ul>
          </div>
          <div class="bg-red-50/50 rounded-2xl p-6 border border-red-100">
            <h3 class="text-sm font-black text-red-800 uppercase tracking-widest mb-4 flex items-center gap-2">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
              Limitations
            </h3>
            <ul class="space-y-3">
              {integration.cons.map(con => (
                <li class="flex items-start gap-2 text-sm text-slate-700"><span class="text-red-500 font-bold mt-0.5">-</span> {con}</li>
              ))}
            </ul>
          </div>
        </div>

        <div class="bg-white rounded-3xl shadow-lg shadow-slate-100/50 border border-slate-200 p-8 md:p-10 mb-10 prose prose-slate max-w-none prose-headings:font-black prose-p:text-slate-700 prose-p:leading-relaxed">
          <h2 class="text-3xl font-black mb-6 pb-4 border-b border-slate-100 flex items-center gap-3">
            <svg class="w-7 h-7 text-indigo-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"></path></svg>
            Architecture & Data Flow Analysis
          </h2>
          <div class="space-y-6 text-sm leading-relaxed">
            {integration.ai_technical_analysis.split('\n').filter(p => p.trim() !== '').map((paragraph) => (
              <p>{paragraph}</p>
            ))}
          </div>
        </div>

        <div class="bg-amber-50 border-l-4 border-amber-500 rounded-r-2xl p-6 mb-10">
          <h3 class="text-xs font-black text-amber-900 uppercase tracking-widest mb-2 font-mono">Critical Friction Warning</h3>
          <p class="text-amber-950 text-sm font-medium">{integration.technical_warning}</p>
        </div>

        <div class="bg-slate-900 rounded-3xl p-8 md:p-10 text-white mb-8">
          <h3 class="text-2xl font-black mb-8 flex items-center gap-3">
            <svg class="w-6 h-6 text-indigo-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"></path></svg>
            Deployment Protocol
          </h3>
          <div class="space-y-6">
            {integration.integration_steps.map((step, index) => (
              <div class="flex gap-5 items-start">
                <div class="w-8 h-8 rounded-full bg-indigo-600 flex items-center justify-center font-bold font-mono text-sm shrink-0 mt-0.5 shadow-lg shadow-indigo-500/30">
                  {index + 1}
                </div>
                <p class="text-slate-300 text-sm leading-relaxed">{step}</p>
              </div>
            ))}
          </div>
        </div>

      </main>

      <aside class="lg:col-span-4 relative">
        <div class="sticky top-24 bg-white rounded-3xl p-8 shadow-xl shadow-slate-200/50 border border-slate-200">
          
          <div class="flex items-center justify-between mb-8 pb-6 border-b border-slate-100 gap-4">
            <div>
              <div class="text-[11px] font-mono text-indigo-500 mb-1.5 uppercase tracking-widest">Base Platform</div>
              <h3 class="text-2xl font-black text-slate-950">{crmData.name}</h3>
            </div>
            {crmData.has_free_tier && (
              <span class="bg-emerald-100 text-emerald-800 text-xs font-bold px-2.5 py-1 rounded-full uppercase tracking-wide">Free Tier</span>
            )}
          </div>
          
          <div class="mb-8 p-4 bg-slate-50 rounded-xl border border-slate-100">
            <div class="text-sm text-slate-500 mb-1.5 font-medium">Starting at</div>
            <div class="text-4xl font-black text-slate-950 mb-1 flex items-baseline gap-1">
              ${crmData.starting_price}
              <span class="text-lg text-slate-400 font-normal">/mo</span>
            </div>
            <div class="text-[11px] text-slate-400 font-mono uppercase tracking-wide">{crmData.primary_category}</div>
          </div>

          <ul class="space-y-4 mb-10">
            {crmData.features.map(feature => (
              <li class="flex items-center gap-3.5 text-sm text-slate-700 font-medium">
                <svg class="w-5 h-5 text-indigo-500 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                {feature}
              </li>
            ))}
          </ul>

          <a href={crmData.affiliate_url} target="_blank" rel="noopener noreferrer" class="block w-full bg-slate-950 hover:bg-indigo-600 text-white text-center font-bold py-4 px-6 rounded-2xl transition-all shadow-lg shadow-slate-900/10 mb-5">
            Verify Integrations & Pricing
          </a>
          
          <div class="text-center text-xs text-slate-400 font-mono">
            Direct link to official {crmData.name} portal.
          </div>
        </div>
      </aside>

    </div>
  </div>
</Layout>